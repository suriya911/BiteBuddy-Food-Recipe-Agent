aws_region      = "us-east-1"
project_name    = "bitebuddy"
instance_type   = "t2.micro"
key_pair_name   = "your-existing-keypair-name"
ssh_cidrs       = ["YOUR_PUBLIC_IP/32"]
backend_port    = 8000
root_volume_size_gb = 20

backend_image = "ghcr.io/your-org/bitebuddy-backend:latest"

backend_env = {
  APP_NAME                  = "BiteBuddy API"
  APP_ENV                   = "production"
  API_V1_PREFIX             = "/api"
  HOST                      = "0.0.0.0"
  PORT                      = "8000"
  CORS_ORIGINS              = "[\"https://your-frontend.vercel.app\"]"
  USE_LARGE_CORPUS_INDEX    = "false"
  ENABLE_NEURAL_RERANKER    = "false"
  INDEXED_CANDIDATE_LIMIT   = "120"
}
