APP_NAME=BiteBuddy API
APP_ENV=development
API_V1_PREFIX=/api
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
YOUTUBE_API_KEY=
KAGGLE_USERNAME=
KAGGLE_KEY=
USE_LARGE_CORPUS_INDEX=false
RECIPE_SEARCH_INDEX_PATH=backend/data/processed/recipe_search.sqlite
INDEXED_CANDIDATE_LIMIT=120
ENABLE_NEURAL_RERANKER=false
NEURAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
NEURAL_RERANK_TOP_K=25
AUTH_DB_PATH=backend/data/processed/auth.sqlite
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
OTP_EXPIRY_MINUTES=10
ENABLE_LANGGRAPH=false
HF_API_KEY=
HF_MODEL=
HF_MAX_TOKENS=220
HF_TEMPERATURE=0.4
HF_TIMEOUT_SECONDS=30
USE_QDRANT=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTIONS=recipes_foodcom_e5_base,recipes_foodcom_bge,recipes_foodcom_bge_small
QDRANT_MODELS=intfloat/e5-base-v2,BAAI/bge-base-en-v1.5,BAAI/bge-small-en-v1.5
QDRANT_DEFAULT_COLLECTION=recipes_foodcom_e5_base
QDRANT_TOP_K=10
QDRANT_LOW_SCORE_THRESHOLD=0.25
QDRANT_SHORT_QUERY_TOKENS=4
FOODCOM_RECIPES_CSV=backend/data/raw/shuyangli94__food-com-recipes-and-user-interactions/recipes.csv
FOODCOM_DETAILS_DB=backend/data/processed/recipe_details.sqlite
USE_GRAPH=false
GRAPH_MAX_CANDIDATES=200
GRAPH_WEIGHT=0.3
VECTOR_WEIGHT=0.7
USE_POSTGRES_AUTH=false
POSTGRES_AUTH_DSN=postgresql://bitebuddy:bitebuddy@localhost:5432/bitebuddy
POSTGRES_DSN=postgresql://bitebuddy:bitebuddy@localhost:5432/bitebuddy
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
